# ============================================================
# KONFIGURASI ENVIRONMENT - NANAS GRADING BACKEND
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env asli ke repository!
# ============================================================

# --- Database MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=db_nanas_grading
DB_ECHO=False  # Set True untuk debug SQL query

# --- JWT Authentication ---
JWT_SECRET_KEY=ganti_dengan_random_string_panjang_minimal_32_karakter
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24 jam

# --- Aplikasi ---
APP_NAME=Nanas Grading API
APP_VERSION=1.0.0
APP_ENV=development  # development | production
DEBUG=True

# --- Upload File ---
UPLOAD_DIR=app/static/uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# --- Model YOLO ---
YOLO_WEIGHTS_PATH=weights/yolov11_nanas.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_DEVICE=cpu  # cpu | cuda:0

# --- CORS ---
# Pisahkan dengan koma untuk multiple origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
