# ===== Python (backend) =====
backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/.pytest_cache/
backend/*.egg-info/

# Environment variables (JANGAN commit secret/password)
backend/.env
frontend/.env

# Model weights (biasanya besar, jangan commit ke git)
backend/weights/*.pt
backend/weights/*.onnx
!backend/weights/.gitkeep

# Upload foto user (data runtime, bukan source code)
backend/app/static/uploads/*
!backend/app/static/uploads/.gitkeep

# Database lokal (kalau pakai sqlite untuk testing)
backend/*.db
backend/*.sqlite3

# ===== Node (frontend) =====
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.local

# ===== Editor & OS =====
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ===== Logs =====
*.log
npm-debug.log*